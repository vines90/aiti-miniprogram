.page {
  padding: 24rpx 32rpx 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.page.empty {
  padding-top: 100rpx;
  text-align: center;
}

.celebrate {
  font-size: 40rpx;
  color: rgba(110, 231, 255, 0.5);
  margin-bottom: 16rpx;
  letter-spacing: 0.1em;
}

.result-card {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  padding: 40rpx 36rpx 44rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: linear-gradient(
    165deg,
    rgba(55, 48, 88, 0.55) 0%,
    rgba(22, 18, 38, 0.92) 42%,
    rgba(10, 8, 18, 0.98) 100%
  );
  border: 1rpx solid rgba(167, 139, 250, 0.35);
  box-shadow: 0 28rpx 88rpx rgba(0, 0, 0, 0.4), 0 0 0 1rpx rgba(255, 255, 255, 0.04) inset;
  margin-bottom: 44rpx;
}

.card-shine {
  position: absolute;
  top: -40%;
  right: -20%;
  width: 70%;
  height: 80%;
  background: radial-gradient(circle, rgba(110, 231, 255, 0.12) 0%, transparent 65%);
  pointer-events: none;
}

.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.label {
  font-size: 24rpx;
  color: rgba(236, 233, 247, 0.5);
  letter-spacing: 0.2em;
  margin-bottom: 16rpx;
}

.tag-pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #6ee7ff;
  background: rgba(110, 231, 255, 0.1);
  border: 1rpx solid rgba(110, 231, 255, 0.35);
}

.name {
  display: block;
  text-align: center;
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 0.04em;
  line-height: 1.2;
  margin-bottom: 12rpx;
}

.en {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #c4b5fd;
  letter-spacing: 0.12em;
  margin-bottom: 32rpx;
}

.divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15));
}

.divider::after {
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.15), transparent);
}

.divider-dot {
  width: 8rpx;
  height: 8rpx;
  margin: 0 20rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6ee7ff, #a78bfa);
}

.desc-box {
  position: relative;
  padding: 24rpx 24rpx 24rpx 36rpx;
  background: rgba(0, 0, 0, 0.22);
  border-radius: 16rpx;
  overflow: hidden;
}

.desc-bar {
  position: absolute;
  left: 0;
  top: 16rpx;
  bottom: 16rpx;
  width: 6rpx;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #6ee7ff 0%, #a78bfa 100%);
}

.desc {
  font-size: 30rpx;
  line-height: 1.75;
  color: rgba(236, 233, 247, 0.9);
  text-align: left;
}

.btn-share {
  width: 100%;
  max-width: 580rpx;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  border-radius: 48rpx;
  font-size: 0;
  border: none;
  background: linear-gradient(135deg, #5eead4 0%, #6ee7ff 40%, #a78bfa 100%);
  box-shadow: 0 12rpx 40rpx rgba(110, 231, 255, 0.22);
  margin-bottom: 22rpx;
}

.btn-share::after {
  border: none;
}

.btn-share-txt {
  font-size: 32rpx;
  font-weight: 700;
  color: #0a0812;
  letter-spacing: 0.08em;
}

.btn-ghost {
  width: 100%;
  max-width: 580rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  color: rgba(236, 233, 247, 0.88);
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.btn-ghost::after {
  border: none;
}

.btn-ghost-wide {
  max-width: 480rpx;
  margin-top: 16rpx;
}

.empty-icon {
  display: block;
  font-size: 48rpx;
  color: rgba(110, 231, 255, 0.35);
  margin-bottom: 24rpx;
}

.empty-text {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: rgba(236, 233, 247, 0.75);
  margin-bottom: 12rpx;
}

.empty-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(236, 233, 247, 0.42);
  margin-bottom: 48rpx;
  padding: 0 48rpx;
  line-height: 1.5;
}
