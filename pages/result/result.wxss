.page {
  padding: 40rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page.empty {
  padding-top: 120rpx;
}

.result-card {
  width: 100%;
  box-sizing: border-box;
  padding: 48rpx 36rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, rgba(46, 42, 72, 0.95) 0%, rgba(18, 16, 26, 0.98) 100%);
  border: 1rpx solid rgba(167, 139, 250, 0.35);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.35);
  margin-bottom: 48rpx;
  text-align: center;
}

.label {
  display: block;
  font-size: 24rpx;
  color: rgba(232, 230, 242, 0.55);
  letter-spacing: 0.12em;
  margin-bottom: 20rpx;
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  color: #7ae8ff;
  border: 1rpx solid rgba(122, 232, 255, 0.4);
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  margin-bottom: 16rpx;
}

.name {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.en {
  display: block;
  font-size: 28rpx;
  color: #a78bfa;
  letter-spacing: 0.08em;
  margin-bottom: 32rpx;
}

.line {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.12);
  margin-bottom: 32rpx;
}

.desc {
  display: block;
  font-size: 30rpx;
  line-height: 1.6;
  color: rgba(232, 230, 242, 0.88);
  text-align: left;
}

.btn-share {
  width: 100%;
  max-width: 560rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #12101a;
  background: linear-gradient(90deg, #7ae8ff 0%, #a78bfa 100%);
  border: none;
  margin-bottom: 24rpx;
}

.btn-share::after {
  border: none;
}

.btn-ghost {
  width: 100%;
  max-width: 560rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: rgba(232, 230, 242, 0.85);
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.btn-ghost::after {
  border: none;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(232, 230, 242, 0.5);
  margin-bottom: 40rpx;
}
