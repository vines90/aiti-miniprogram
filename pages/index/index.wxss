.page {
  padding: 32rpx 40rpx 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  min-height: 88vh;
}

.brand-mark {
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28rpx;
  color: rgba(110, 231, 255, 0.35);
  letter-spacing: 0.2em;
}

.hero {
  text-align: center;
  margin-top: 72rpx;
  margin-bottom: 56rpx;
  width: 100%;
}

.badge-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 36rpx;
}

.badge {
  font-size: 22rpx;
  color: rgba(110, 231, 255, 0.92);
  letter-spacing: 0.06em;
}

.badge-dot {
  font-size: 22rpx;
  color: rgba(236, 233, 247, 0.25);
}

.title {
  display: block;
  font-size: 108rpx;
  font-weight: 800;
  letter-spacing: 0.28em;
  text-indent: 0.14em;
  line-height: 1.05;
  background: linear-gradient(165deg, #ffffff 0%, #ddd6fe 38%, #6ee7ff 72%, #67e8f9 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  margin-bottom: 12rpx;
}

.title-underline {
  width: 120rpx;
  height: 6rpx;
  margin: 0 auto 28rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, transparent, #6ee7ff 40%, #a78bfa 100%);
  opacity: 0.85;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(236, 233, 247, 0.72);
  letter-spacing: 0.12em;
  margin-bottom: 28rpx;
}

.hook {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #f4f0ff;
  letter-spacing: 0.04em;
  line-height: 1.35;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 56rpx;
  max-width: 620rpx;
}

.chip {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(167, 139, 250, 0.22);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
}

.chip-wide {
  padding-left: 26rpx;
  padding-right: 26rpx;
}

.chip-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #6ee7ff;
}

.chip-txt {
  font-size: 24rpx;
  color: rgba(236, 233, 247, 0.65);
}

.btn-start {
  width: 100%;
  max-width: 580rpx;
  height: 100rpx;
  padding: 0;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 0;
  border: none;
  background: linear-gradient(135deg, #5eead4 0%, #6ee7ff 35%, #a78bfa 100%);
  box-shadow: 0 12rpx 40rpx rgba(110, 231, 255, 0.28), 0 4rpx 0 rgba(255, 255, 255, 0.12) inset;
}

.btn-start::after {
  border: none;
}

.btn-start-inner {
  font-size: 34rpx;
  font-weight: 700;
  color: #0a0812;
  letter-spacing: 0.14em;
}

.hint {
  margin-top: 28rpx;
  font-size: 24rpx;
  color: rgba(236, 233, 247, 0.38);
}

.footer-note {
  margin-top: auto;
  padding-top: 80rpx;
  font-size: 22rpx;
  color: rgba(236, 233, 247, 0.28);
}
