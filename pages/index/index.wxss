.page {
  padding: 48rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero {
  text-align: center;
  margin-top: 80rpx;
  margin-bottom: 48rpx;
}

.badge {
  display: inline-block;
  font-size: 22rpx;
  color: #7ae8ff;
  border: 1rpx solid rgba(122, 232, 255, 0.45);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  margin-bottom: 32rpx;
  letter-spacing: 0.08em;
}

.title {
  display: block;
  font-size: 96rpx;
  font-weight: 700;
  letter-spacing: 0.2em;
  background: linear-gradient(135deg, #fff 0%, #c4b5fd 45%, #7ae8ff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 30rpx;
  color: rgba(232, 230, 242, 0.85);
  margin-bottom: 24rpx;
}

.hook {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #f0ebff;
}

.meta {
  margin-bottom: 64rpx;
}

.meta-line {
  font-size: 24rpx;
  color: rgba(232, 230, 242, 0.45);
}

.btn-start {
  width: 100%;
  max-width: 560rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #12101a;
  background: linear-gradient(90deg, #7ae8ff 0%, #a78bfa 100%);
  border: none;
  box-shadow: 0 16rpx 48rpx rgba(122, 232, 255, 0.25);
}

.btn-start::after {
  border: none;
}

.footer-note {
  margin-top: 48rpx;
  font-size: 22rpx;
  color: rgba(232, 230, 242, 0.35);
}
