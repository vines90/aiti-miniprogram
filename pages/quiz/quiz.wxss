.page {
  padding: 24rpx 32rpx 80rpx;
}

.progress-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  margin-bottom: 12rpx;
  padding-right: 8rpx;
}

.progress-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #7ae8ff;
}

.progress-sep {
  font-size: 24rpx;
  color: rgba(232, 230, 242, 0.35);
  margin: 0 6rpx;
}

.progress-total {
  font-size: 26rpx;
  color: rgba(232, 230, 242, 0.5);
}

.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #7ae8ff, #a78bfa);
  border-radius: 4rpx;
  transition: width 0.2s ease;
}

.card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 40rpx;
}

.q-text {
  font-size: 32rpx;
  line-height: 1.55;
  color: #f2f0fa;
  font-weight: 500;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.opt {
  display: flex;
  align-items: flex-start;
  text-align: left;
  padding: 28rpx 28rpx;
  border-radius: 20rpx;
  background: rgba(30, 27, 45, 0.95);
  border: 1rpx solid rgba(167, 139, 250, 0.2);
  color: #e8e6f2;
  font-size: 28rpx;
  line-height: 1.45;
}

.opt::after {
  border: none;
}

.opt-label {
  flex-shrink: 0;
  width: 44rpx;
  font-weight: 700;
  color: #a78bfa;
  margin-right: 16rpx;
}

.opt-text {
  flex: 1;
}
