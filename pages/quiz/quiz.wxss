.page {
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx 32rpx 48rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding: 0 4rpx;
}

.brand {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: rgba(110, 231, 255, 0.55);
}

.step-pill {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(167, 139, 250, 0.12);
  border: 1rpx solid rgba(167, 139, 250, 0.28);
}

.step-label {
  font-size: 22rpx;
  color: rgba(236, 233, 247, 0.55);
}

.step-num {
  font-size: 34rpx;
  font-weight: 800;
  color: #6ee7ff;
  min-width: 48rpx;
  text-align: center;
}

.progress-wrap {
  margin-bottom: 36rpx;
}

.progress-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
  padding: 0 6rpx;
}

.remain {
  font-size: 24rpx;
  color: rgba(236, 233, 247, 0.45);
}

.pct {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(167, 139, 250, 0.85);
  font-variant-numeric: tabular-nums;
}

.progress-track {
  position: relative;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5eead4 0%, #6ee7ff 45%, #a78bfa 100%);
  border-radius: 12rpx;
  transition: width 0.22s ease;
  box-shadow: 0 0 16rpx rgba(110, 231, 255, 0.35);
}

.card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.055);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 28rpx;
  padding: 28rpx 32rpx 36rpx;
  margin-bottom: 36rpx;
  box-shadow: 0 24rpx 64rpx rgba(0, 0, 0, 0.22);
}

.card-accent {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #6ee7ff 0%, #a78bfa 100%);
  border-radius: 6rpx 0 0 6rpx;
}

.q-row {
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.q-index {
  font-size: 22rpx;
  font-weight: 700;
  color: rgba(167, 139, 250, 0.9);
  letter-spacing: 0.06em;
}

.q-text {
  display: block;
  padding-left: 8rpx;
  font-size: 34rpx;
  line-height: 1.55;
  color: #f5f2ff;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.options {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 覆盖 button 默认非全宽、边距，与题干卡片同宽 */
.opt {
  width: 100%;
  box-sizing: border-box;
  margin: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  text-align: left;
  min-height: 152rpx;
  padding: 24rpx 28rpx 24rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(18, 14, 32, 0.72);
  border: 1rpx solid rgba(167, 139, 250, 0.22);
  color: rgba(236, 233, 247, 0.94);
  font-size: 28rpx;
  line-height: 1.55;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.2);
}

.opt-badge {
  flex-shrink: 0;
  align-self: center;
  width: 56rpx;
  height: 56rpx;
  margin-right: 22rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 56rpx;
  text-align: center;
  color: #0a0812;
  background: linear-gradient(145deg, #c4b5fd 0%, #6ee7ff 100%);
  box-shadow: 0 4rpx 12rpx rgba(110, 231, 255, 0.2);
}

.opt-text {
  flex: 1;
  min-width: 0;
  word-break: break-word;
  overflow-wrap: break-word;
}
