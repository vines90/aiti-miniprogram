<view class="page safe-bottom">
  <view class="top-bar">
    <text class="brand">AITI</text>
    <view class="step-pill">
      <text class="step-label">第</text>
      <text class="step-num">{{ currentIndex + 1 }}</text>
      <text class="step-label">题</text>
    </view>
  </view>

  <view class="progress-wrap">
    <view class="progress-meta">
      <text class="remain">剩余 {{ remaining }} 题</text>
      <text class="pct">{{ progressPercentInt }}%</text>
    </view>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{ progressPercent }}%;"></view>
    </view>
  </view>

  <view class="card">
    <view class="card-accent"></view>
    <view class="q-row">
      <text class="q-index">Q{{ currentIndex + 1 }}</text>
    </view>
    <text class="q-text">{{ question.text }}</text>
  </view>

  <view class="options">
    <view
      wx:for="{{ question.options }}"
      wx:for-index="optIdx"
      wx:key="optIdx"
      class="opt"
      hover-class="hover-surface"
      hover-start-time="10"
      hover-stay-time="70"
      data-index="{{ optIdx }}"
      bindtap="onPick"
    >
      <view class="opt-badge">{{ labels[optIdx] }}</view>
      <text class="opt-text">{{ item.text }}</text>
    </view>
  </view>
</view>
